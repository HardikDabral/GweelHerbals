{%- comment -%}
  Gweel Herbals — Floating Navbar / Header
  Drop this into your theme's /sections folder. Either replace the theme's
  header group with this section, or add it to your home page template.
  Pick the menu under "Navigation menu" in the theme editor (default: main-menu).
{%- endcomment -%}

<nav class="gweel-nav" style="--gweel-gold: {{ section.settings.accent_color }};">
  <div class="gweel-nav__pill">
    {%- comment -%} Left: desktop nav links {%- endcomment -%}
    <ul class="gweel-nav__links">
      {%- for link in linklists[section.settings.menu].links -%}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {%- endfor -%}
    </ul>

    {%- comment -%} Center: brand {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="gweel-nav__brand">{{ section.settings.brand_name }}</a>

    {%- comment -%} Right: CTA button (desktop) {%- endcomment -%}
    <div class="gweel-nav__right">
      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="gweel-nav__cta"
          {% if section.settings.button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Mobile hamburger {%- endcomment -%}
    <button class="gweel-nav__burger" aria-label="Open menu" onclick="document.getElementById('gweelDrawer').classList.add('is-open')">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</nav>

{%- comment -%} Mobile drawer {%- endcomment -%}
<div class="gweel-drawer" id="gweelDrawer">
  <div class="gweel-drawer__backdrop" onclick="document.getElementById('gweelDrawer').classList.remove('is-open')"></div>
  <aside class="gweel-drawer__panel">
    <button class="gweel-drawer__close" aria-label="Close menu" onclick="document.getElementById('gweelDrawer').classList.remove('is-open')">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <nav class="gweel-drawer__links">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>
    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link }}"
        class="gweel-drawer__cta"
        {% if section.settings.button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </aside>
</div>

<style>
  .gweel-nav {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    width: 100%;
    max-width: 1200px;
    padding: 0 1rem;
    box-sizing: border-box;
  }
  .gweel-nav *, .gweel-drawer * { box-sizing: border-box; }

  .gweel-nav__pill {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    padding: 0 0.75rem 0 1.75rem;
    border-radius: 9999px;
    background: rgba(26, 26, 26, 0.85);
    border: 1px solid color-mix(in srgb, var(--gweel-gold) 20%, transparent);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
  }

  .gweel-nav__links {
    display: flex;
    align-items: center;
    gap: 2.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .gweel-nav__links a {
    color: #fff;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .gweel-nav__links a:hover { opacity: 0.8; }

  .gweel-nav__brand {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .gweel-nav__right { display: flex; align-items: center; }
  .gweel-nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.75rem;
    border-radius: 9999px;
    background: var(--gweel-gold);
    color: #1a1a1a;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--gweel-gold) 80%, transparent);
    box-shadow: 0 4px 12px rgba(254, 190, 16, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transition: background 0.3s ease, box-shadow 0.3s ease;
    white-space: nowrap;
  }
  .gweel-nav__cta:hover { background: #ffc832; box-shadow: 0 6px 16px rgba(254, 190, 16, 0.4); }

  .gweel-nav__burger {
    display: none;
    background: transparent;
    border: 0;
    color: #fff;
    padding: 0.5rem;
    cursor: pointer;
  }

  /* Mobile drawer */
  .gweel-drawer { position: fixed; inset: 0; z-index: 60; visibility: hidden; }
  .gweel-drawer.is-open { visibility: visible; }
  .gweel-drawer__backdrop {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0; transition: opacity 0.3s ease;
  }
  .gweel-drawer.is-open .gweel-drawer__backdrop { opacity: 1; }
  .gweel-drawer__panel {
    position: absolute; top: 0; right: 0; height: 100%;
    width: 320px; max-width: 85vw;
    background: #1a1a1a;
    padding: 1.5rem;
    display: flex; flex-direction: column;
    transform: translateX(100%); transition: transform 0.3s ease;
    box-shadow: -10px 0 40px rgba(0, 0, 0, 0.4);
  }
  .gweel-drawer.is-open .gweel-drawer__panel { transform: translateX(0); }
  .gweel-drawer__close { align-self: flex-end; background: transparent; border: 0; color: #fff; cursor: pointer; padding: 0.5rem; }
  .gweel-drawer__links { display: flex; flex-direction: column; gap: 1.5rem; margin: 1.5rem 0; }
  .gweel-drawer__links a { color: #fff; font-size: 1.125rem; font-weight: 500; text-decoration: none; transition: color 0.2s ease; }
  .gweel-drawer__links a:hover { color: var(--gweel-gold); }
  .gweel-drawer__cta {
    margin-top: auto;
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 0.85rem 1.5rem; border-radius: 9999px;
    background: var(--gweel-gold); color: #1a1a1a; font-weight: 600; text-decoration: none;
  }

  @media (max-width: 1024px) {
    .gweel-nav__links, .gweel-nav__right { display: none; }
    .gweel-nav__brand { left: 1.75rem; transform: none; font-size: 1.25rem; }
    .gweel-nav__burger { display: inline-flex; }
    .gweel-nav__pill { padding-right: 0.75rem; }
  }
</style>

{% schema %}
{
  "name": "Gweel Header",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Gweel Herbals"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Buy on Amazon"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "https://www.amazon.in"
    },
    {
      "type": "checkbox",
      "id": "button_new_tab",
      "label": "Open button link in new tab",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#FEBE10"
    }
  ]
}
{% endschema %}
